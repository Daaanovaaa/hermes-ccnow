# ============================================================
# HERMES CC NOW! — Environment Variables Template
# Copy this file to /root/.hermes/.env and fill in all values.
# NEVER commit the real .env file.
# ============================================================

# --- NVIDIA NIM (default model for daily automation) ---
NVIDIA_API_KEY=

# --- OpenRouter / Cerebras (content generation) ---
OPENROUTER_API_KEY=

# --- Plaid (banking — production) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
FIFTH_THIRD_ACCESS_TOKEN=
BANCO_POPULAR_ACCESS_TOKEN=

# --- Telegram (Hermes gateway) ---
TELEGRAM_BOT_TOKEN=

# --- Google Workspace ---
# Auth handled by /root/.hermes/google_token.json (OAuth flow)
# Do not put Google credentials here — run: hermes setup google

# --- PayPal (future integration) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=production
