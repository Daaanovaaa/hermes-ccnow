    {
      "id": "n09",
      "name": "Mark as Posted",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2120,
        540
      ],
      "parameters": {
        "jsCode": "// Record posted URL in workflow static data\nconst url = $('Extract & Deduplicate').first().json.url;\nconst sd  = $workflow.staticData;\nif (!sd.postedUrls) sd.postedUrls = [];\nif (!sd.postedUrls.includes(url)) {\n  sd.postedUrls.push(url);\n  if (sd.postedUrls.length > 200) sd.postedUrls = sd.postedUrls.slice(-200);\n}\nconst postizResp = $input.first().json;\nreturn [{ json: { marked: true, url, postizId: postizResp.id || null } }];"
      }
    },
