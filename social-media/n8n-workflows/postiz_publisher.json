    {
      "id": "n02",
      "name": "Fetch Latest Substack Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://danova.substack.com/api/v1/posts?limit=1",
        "options": {}
      }
    },
    {
      "id": "n03",
      "name": "Extract & Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "jsCode": "// Pull latest Substack post, skip if already published\nconst posts = $input.first().json;\nconst post = Array.isArray(posts) ? posts[0] : (posts.posts ? posts.posts[0] : posts);\n\nconst title    = post.title    || 'New from CCN';\nconst subtitle = post.subtitle || '';\nconst slug     = post.slug     || '';\nconst url      = `https://danova.substack.com/p/${slug}`;\nconst imageUrl = post.cover_image || '';\n\n// Deduplication via workflow static data\nconst sd = $workflow.staticData;\nif (!sd.postedUrls) sd.postedUrls = [];\n\nif (sd.postedUrls.includes(url)) {\n  return [{ json: { skip: true, url, reason: 'Already posted' } }];\n}\n\nconst tags = '#ConsciousCultureNOW #CCNow #Kingdom #Faith #HipHop #ElPabellon';\nconst message = `\u271d\ufe0f ${title}\\n\\n${subtitle}\\n\\nRead more \u2192 ${url}\\n\\n${tags}`;\n\nreturn [{ json: { skip: false, title, subtitle, url, imageUrl, message } }];"
      }
    },
    {
      "id": "n04",
      "name": "Already Posted?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        920,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
