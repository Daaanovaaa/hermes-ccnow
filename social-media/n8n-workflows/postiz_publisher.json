    {
      "id": "n05b",
      "name": "Get Postiz Integrations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1160,
        420
      ],
      "parameters": {
        "method": "GET",
        "url": "https://postiz.faaaith.org/api/public/v1/integrations",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "985c33d79592da8291de87e1afbca6f02f3a5e8f5aa54d877455087441c4b76f"
            }
          ]
        }
      }
    },
    {
      "id": "n06",
      "name": "Build Postiz Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        420
      ],
      "parameters": {
        "jsCode": "// Map Postiz integration identifiers \u2192 __type settings object\nconst postData    = $('Extract & Deduplicate').first().json;\nconst integrations = $input.all().map(i => i.json);\n\nif (!integrations || integrations.length === 0) {\n  return [{ json: { skip: true, reason: 'No integrations connected in Postiz' } }];\n}\n\nconst typeMap = {\n  'facebook':            'facebook',\n  'facebook-page':       'facebook',\n  'instagram':           'instagram_graph',\n  'instagram-standalone':'instagram',\n  'threads':             'threads',\n  'linkedin':            'linkedin',\n  'linkedin-page':       'linkedin-page',\n  'x':                   'x',\n  'twitter':             'x',\n  'youtube':             'youtube',\n  'tiktok':              'tiktok',\n  'reddit':              'reddit',\n  'telegram':            'telegram',\n  'bluesky':             'bluesky',\n  'mastodon':            'mastodon',\n  'discord':             'discord',\n  'slack':               'slack',\n  'medium':              'medium',\n  'pinterest':           'pinterest',\n  'whatsapp':            'whatsapp',\n};\n\nconst posts = integrations\n  .filter(i => !i.disabled)\n  .map(i => {\n    const type = typeMap[i.identifier] || i.identifier;\n    return {\n      integration: { id: i.id },\n      value: [{ content: postData.message, image: [] }],\n      settings: { __type: type }\n    };\n  });\n\nreturn [{ json: { skip: false, posts, count: posts.length } }];"
      }
    },
