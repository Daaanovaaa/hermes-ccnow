#!/usr/bin/env python3
"""
Embedding Generator for CCN Voice Corpus
Creates embeddings from text files and stores them in ChromaDB
"""
import os
import logging
import requests
import json
from typing import List
import chromadb
from chromadb.config import Settings

# Setup directories
BASE_DIR = "/root/hermes-ccnow/voice-corpus"
RAW_TEXT_DIR = os.path.join(BASE_DIR, "raw_text")
LOGS_DIR = os.path.join(BASE_DIR, "logs")
DB_PATH = os.path.join(BASE_DIR, "corpus.db")

# Ensure directories exist
os.makedirs(RAW_TEXT_DIR, exist_ok=True)
os.makedirs(LOGS_DIR, exist_ok=True)

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler(os.path.join(LOGS_DIR, "corpus.log")),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

# Configuration
OLLAMA_URL = "http://localhost:11434/api/embeddings"
MODEL_NAME = "nomic-embed-text"
COLLECTION_NAME = "ccn_voice"
CHUNK_SIZE = 400  # tokens (approximated by characters)
OVERLAP_SIZE = 50  # tokens

def check_ollama():
    """Check if Ollama is running and the model is available"""
    try:
        # Check if Ollama is responding
        response = requests.get("http://localhost:11434/api/tags", timeout=5)
        if response.status_code != 200:
            logger.error("Ollama is not responding")
            return False
        
        # Check if our model is available
        data = response.json()
        models = [model['name'] for model in data.get('models', [])]
        # Check for exact match or model with :latest suffix
        model_found = MODEL_NAME in models or f"{MODEL_NAME}:latest" in models
        if not model_found:
            logger.error(f"Model {MODEL_NAME} not found in Ollama. Available models: {models}")
            logger.error(f"Please run: ollama pull {MODEL_NAME}")
            return False
        
        logger.info(f"Ollama is running with model {MODEL_NAME} available")
        return True
    except requests.exceptions.RequestException as e:
        logger.error(f"Failed to connect to Ollama: {str(e)}")
        logger.error("Please ensure Ollama is running: ollama serve")
        return False

def get_embedding(text: str) -> List[float]:
    """Get embedding for text using Ollama"""
    try:
        payload = {
            "model": MODEL_NAME,
            "prompt": text
        }
        response = requests.post(OLLAMA_URL, json=payload, timeout=30)
        response.raise_for_status()
        
        data = response.json()
        embedding = data.get('embedding')
        if embedding is None:
            logger.error(f"No embedding returned from Ollama: {data}")
            return None
        return embedding
    except Exception as e:
        logger.error(f"Failed to get embedding: {str(e)}")
        return None

def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = OVERLAP_SIZE) -> List[str]:
    """Split text into chunks with overlap"""
    # Simple character-based chunking (approximation for tokens)
    # In production, you might want to use a proper tokenizer
    chunks = []
    start = 0
    text_length = len(text)
    
    while start < text_length:
        end = start + chunk_size
        chunk = text[start:end]
        chunks.append(chunk)
        start = end - overlap
        
        # Avoid infinite loop on small texts
        if end >= text_length:
            break
        
    return chunks

def main():
    logger.info("Starting embedding generation")
    
    # Check Ollama
    if not check_ollama():
        return
    
    # Initialize ChromaDB
    try:
        client = chromadb.PersistentClient(path=DB_PATH)
        # Try to get existing collection, create if doesn't exist
        try:
            collection = client.get_collection(name=COLLECTION_NAME)
            logger.info(f"Using existing collection: {COLLECTION_NAME}")
        except:
            collection = client.create_collection(name=COLLECTION_NAME)
            logger.info(f"Created new collection: {COLLECTION_NAME}")
    except Exception as e:
        logger.error(f"Failed to initialize ChromaDB: {str(e)}")
        return
    
    # Get all text files
    try:
        files = [f for f in os.listdir(RAW_TEXT_DIR) if f.endswith('.txt')]
        logger.info(f"Found {len(files)} text files to process")
    except Exception as e:
        logger.error(f"Failed to list files in {RAW_TEXT_DIR}: {str(e)}")
        return
    
    total_chunks = 0
    total_files_processed = 0
    
    for filename in files:
        filepath = os.path.join(RAW_TEXT_DIR, filename)
        
        try:
            # Read file
            with open(filepath, 'r', encoding='utf-8') as f:
                text = f.read()
            
            if not text.strip():
                logger.warning(f"Empty file: {filename}")
                continue
                
            # Chunk the text
            chunks = chunk_text(text)
            logger.info(f"File {filename}: {len(chunks)} chunks")
            
            # Process each chunk
            for i, chunk in enumerate(chunks):
                # Create unique ID for this chunk
                chunk_id = f"{filename}_{i}"
                
                # Check if already embedded (simple approach: check if ID exists)
                try:
                    existing = collection.get(ids=[chunk_id])
                    if existing['ids'] and len(existing['ids']) > 0:
                        logger.debug(f"Skipping already embedded chunk: {chunk_id}")
                        continue
                except:
                    # If there's an error checking, we'll try to add and let ChromaDB handle duplicates
                    pass
                
                # Get embedding
                embedding = get_embedding(chunk)
                if embedding is None:
                    logger.error(f"Failed to get embedding for chunk {chunk_id}")
                    continue
                
                # Store in ChromaDB
                try:
                    collection.add(
                        embeddings=[embedding],
                        documents=[chunk],
                        ids=[chunk_id],
                        metadatas=[{"source": filename, "chunk_index": i}]
                    )
                    total_chunks += 1
                    logger.debug(f"Stored chunk {chunk_id}")
                except Exception as e:
                    logger.error(f"Failed to store chunk {chunk_id}: {str(e)}")
            
            total_files_processed += 1
            logger.info(f"Processed file {filename} ({total_files_processed}/{len(files)})")
            
        except Exception as e:
            logger.error(f"Failed to process file {filename}: {str(e)}")
    
    logger.info(f"Embedding generation completed. "
                f"Files processed: {total_files_processed}, "
                f"Chunks embedded: {total_chunks}")

if __name__ == "__main__":
    main()